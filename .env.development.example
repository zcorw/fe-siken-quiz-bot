# Local web origin used in Telegram quiz links during development.
PUBLIC_BASE_URL=http://localhost:3000

# Runtime configuration file.
APP_CONFIG_PATH=./config/app.yaml

# SQLite files for local development.
QUESTION_DB_PATH=./fe_siken_questions.sqlite
APP_DB_PATH=./data/app.sqlite

# OpenAI scope parsing.
OPENAI_API_KEY=

# Telegram bot and webhook verification for local debugging.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_PATH_PREFIX=/telegram/webhook
TELEGRAM_WEBHOOK_PATH_SECRET=dev-path-secret
TELEGRAM_WEBHOOK_SECRET_TOKEN=dev-header-secret
# Optional alias accepted by the bot runtime. TELEGRAM_WEBHOOK_SECRET_TOKEN is kept for existing docs/config.
TELEGRAM_WEBHOOK_HEADER_SECRET=dev-header-secret

# Local bot server.
BOT_HOST=0.0.0.0
BOT_PORT=3001

# Optional local bot file log.
BOT_LOG_FILE=./logs/bot.log
