# Public web origin used in Telegram quiz links.
PUBLIC_BASE_URL=https://example.com

# Runtime configuration file.
APP_CONFIG_PATH=./config/app.yaml

# SQLite files.
QUESTION_DB_PATH=./fe_siken_questions.sqlite
APP_DB_PATH=./data/app.sqlite

# OpenAI scope parsing.
OPENAI_API_KEY=

# Telegram bot and webhook verification.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_PATH_PREFIX=/telegram/webhook
TELEGRAM_WEBHOOK_PATH_SECRET=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Optional alias accepted by the bot runtime. TELEGRAM_WEBHOOK_SECRET_TOKEN is kept for existing docs/config.
TELEGRAM_WEBHOOK_HEADER_SECRET=

# Docker edge listener exposed to the external VPS Nginx.
EDGE_HOST=127.0.0.1
EDGE_PORT=3100
BOT_HOST=0.0.0.0
BOT_PORT=3001
