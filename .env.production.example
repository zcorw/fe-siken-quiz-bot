# Public web origin used in Telegram quiz links.
PUBLIC_BASE_URL=https://example.com

# OpenAI scope parsing.
OPENAI_API_KEY=

# Telegram bot and webhook verification.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_PATH_SECRET=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Optional alias accepted by the bot runtime. TELEGRAM_WEBHOOK_SECRET_TOKEN is kept for existing docs/config.
TELEGRAM_WEBHOOK_HEADER_SECRET=
# Register Telegram webhook automatically when the bot container starts.
TELEGRAM_AUTO_SET_WEBHOOK=true

# Docker edge listener exposed to the external VPS Nginx.
EDGE_HOST=127.0.0.1
EDGE_PORT=3100

# Container runtime paths are set by deploy/docker-compose.yml:
# APP_CONFIG_PATH=/app/config/app.yaml
# APP_DB_PATH=/app/data/app.sqlite
# QUESTION_DB_PATH=/app/data/fe_siken_questions.sqlite
# TELEGRAM_WEBHOOK_PATH_PREFIX=/telegram/webhook
# BOT_HOST=0.0.0.0
# BOT_PORT=3001
#
# VPS host mount overrides are exported automatically by deploy/scripts/deploy.sh:
# HOST_ENV_FILE=/opt/fe-quiz-bot/.env
# HOST_CONFIG_DIR=/opt/fe-quiz-bot/config
# HOST_DATA_DIR=/opt/fe-quiz-bot/data
# HOST_ASSETS_DIR=/opt/fe-quiz-bot/assets
# HOST_LOG_DIR=/opt/fe-quiz-bot/logs
# HOST_DEPLOY_DIR=/opt/fe-quiz-bot/app/deploy
